## 3. Эталонные реализации

### 3.1. Парсинг ответа API (snake_case → camelCase)

```typescript
import { z } from 'zod'

/**
 * Схема валидации операции для GET /api/operations/:id.
 * @description Вход: snake_case от API, выход: camelCase (transform).
 */
export const OperationSchema = z
    .object({
        total_price: z.coerce.number(),
        bonus_paid_amount: z.coerce.number(),
        real_paid_amount: z.coerce.number(),
        status: z.string().optional(),
    })
    .transform(data => ({
        totalPrice: data.total_price,
        bonusPaidAmount: data.bonus_paid_amount,
        realPaidAmount: data.real_paid_amount,
        status: data.status,
    }))

export type Operation = z.infer<typeof OperationSchema>
```

**Использование в TanStack Query:**

```typescript
const rawData = await api.get('/operations/1')
return OperationSchema.parse(rawData) // возвращает Operation
```

### 3.2. Подготовка тела запроса (camelCase → snake_case)

```typescript
import { z } from 'zod'

/**
 * Схема валидации тела запроса обновления операции для PATCH /api/operations/:id.
 * @description Вход: camelCase от UI, выход: snake_case для API (transform).
 */
export const OperationUpdateRequestSchema = z
    .object({
        operationId: z.string().uuid(),
        bonusPaidAmount: z.number().min(0, 'Сумма не может быть отрицательной'),
    })
    .transform(data => ({
        operation_id: data.operationId,
        bonus_paid_amount: data.bonusPaidAmount,
    }))

export type OperationUpdateRequest = z.input<typeof OperationUpdateRequestSchema>
export type OperationUpdateRequestPayload = z.output<typeof OperationUpdateRequestSchema>
```

**Использование перед Axios-мутацией:**

```typescript
export const updateOperation = (payload: OperationUpdateRequest): Promise<unknown> => {
    const apiPayload = OperationUpdateRequestSchema.parse(payload)
    return api.patch(`/operations/${apiPayload.operation_id}`, apiPayload)
}
```

